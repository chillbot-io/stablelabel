# StableLabel Web — Environment Variables
# Copy to .env and fill in your values

# "StableLabel" auth app registration client ID
VITE_ENTRA_CLIENT_ID=your-client-id-here

# Multi-tenant authority (use "common" for multi-tenant)
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/common

# Redirect URI (must match app registration)
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
