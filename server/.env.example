# ── StableLabel — Environment Variables ────────────────────────
# Copy to .env and fill in real values before running docker compose up.

# ── Docker Compose Secrets ──────────────────────────────────────
# REQUIRED — docker-compose.yml references these directly.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── Database ───────────────────────────────────────────────────
# REQUIRED — connection string for PostgreSQL (asyncpg driver).
# docker-compose.yml sets this automatically from POSTGRES_PASSWORD.
# Only override if using an external database.
# SL_DATABASE_URL=postgresql+asyncpg://stablelabel:<password>@postgres:5432/stablelabel

# ── Redis ──────────────────────────────────────────────────────
# REQUIRED — used for the arq task queue and pause signaling.
# docker-compose.yml sets this automatically from REDIS_PASSWORD.
# Only override if using an external Redis.
# SL_REDIS_URL=redis://:<password>@redis:6379/0

# ── Session ────────────────────────────────────────────────────
# REQUIRED — random secret for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SL_SESSION_SECRET=

# ── Entra ID — Auth app (user sign-in via MSAL) ───────────────
# Application (client) ID of the "StableLabel" app registration.
SL_ENTRA_AUTH_CLIENT_ID=

# ── Entra ID — Data Connector app (Graph API access) ──────────
# Application (client) ID and secret for the "StableLabel Data Connector"
# app registration used for admin-consented Graph API calls.
SL_AZURE_CLIENT_ID=
SL_AZURE_CLIENT_SECRET=

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
SL_CORS_ORIGINS=http://localhost:80,http://localhost:5173

# ── Consent callback ──────────────────────────────────────────
# Where Entra ID redirects after admin consent. Must match the
# redirect URI configured in the app registration.
SL_CONSENT_REDIRECT_URI=http://localhost:8000/onboard/callback

# ── Database tuning ──────────────────────────────────────────
# SL_DB_POOL_SIZE=5
# SL_DB_MAX_OVERFLOW=10

# ── Entra ID — Auth tenant ──────────────────────────────────
# SL_ENTRA_AUTH_TENANT_ID=common

# ── Rate limiting (per-tenant Graph API calls) ──────────────
# SL_GRAPH_RATE_LIMIT=5.0
# SL_GRAPH_RATE_BURST=10.0

# ── Bulk operation limits ───────────────────────────────────
# SL_BULK_MAX_CONCURRENT=8
# SL_BULK_VERIFY_DELAY=2.0

# ── Label cache & sync ─────────────────────────────────────
# SL_LABEL_CACHE_TTL=1800.0
# SL_LABEL_SYNC_ENABLED=true
# SL_LABEL_SYNC_INTERVAL_SECONDS=900

# ── Session ─────────────────────────────────────────────────
# SL_SESSION_MAX_AGE=28800

# ── Classifier (optional — requires presidio) ──────────────
# SL_CLASSIFIER_ENABLED=false

# ── Frontend (Vite build-time variables) ───────────────────────
# These are baked into the JS bundle at build time.
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/common
VITE_ENTRA_REDIRECT_URI=http://localhost:80
